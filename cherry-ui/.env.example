# 浏览器请求 Java（须与后端同源策略、CORS 配置一致）
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8080

# SSR 请求 Java（Next 服务端）
BACKEND_URL=http://127.0.0.1:8080

# 与后端 app.jwt.expiration-ms 对齐，仅用于前端展示（如登录页说明）
NEXT_PUBLIC_JWT_EXPIRATION_MS=86400000

# 与后端 app.jwt.cookie-name 一致时，便于文档与后续扩展（Cookie 本身为 httpOnly）
NEXT_PUBLIC_AUTH_JWT_COOKIE_NAME=cherry_jwt

# serverFetch 从 Cookie 读 JWT 写入 Authorization（名称须与后端 Set-Cookie 一致）
AUTH_JWT_COOKIE_NAME=cherry_jwt
